# Get a free API key (no credit card needed) from https://aistudio.google.com/apikey
GEMINI_API_KEY=your-google-ai-studio-key-here

# Which Gemini model to use for every AI feature (analysis, extraction, chat, budget advice).
# gemini-flash-latest is an alias that always points to Google's current default Flash
# model (as of July 2026, that's gemini-3.5-flash) — using the alias means you don't have
# to update this file every time Google deprecates a dated model string. If you hit rate
# limits, gemini-3.1-flash-lite is a higher-quota/cheaper option. Pro-series models are
# paid-only. Check https://ai.google.dev/gemini-api/docs/models for the current list, since
# Google deprecates specific model versions every few months.
GEMINI_MODEL=gemini-flash-latest

# Any long random string — used to sign login sessions. Change this to your own value.
JWT_SECRET=please-change-this-to-a-long-random-string

# Port the server runs on
PORT=3000
